PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173,http://localhost:3000

# MongoDB local connection
MONGODB_URI_LOCAL=mongodb://127.0.0.1:27017/portfolio

# MongoDB Atlas connection
MONGODB_URI_ATLAS=mongodb+srv://USERNAME:PASSWORD@cluster0.mongodb.net/portfolio?retryWrites=true&w=majority

# Optional override if you want to force one URI
MONGODB_URI=

# SMTP mail settings
# Gmail example: EMAIL_SERVICE=gmail with an App Password
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM="Portfolio Contact <your-email@gmail.com>"
ADMIN_EMAIL=your-email@gmail.com
